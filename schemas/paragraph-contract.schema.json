{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scholar Papercraft Paragraph Contract",
  "type": "object",
  "required": ["section", "paragraph", "role", "reader_question", "licensed_claims", "required_evidence", "must_not_include"],
  "properties": {
    "section": {"type": "string"},
    "paragraph": {"type": "string"},
    "role": {
      "type": "string",
      "enum": ["background", "problem_tension", "specific_gap", "key_insight", "method_overview", "definition_setup", "theorem_consequence", "experiment_question", "result_interpretation", "related_work_positioning", "limitation_scope", "transition", "contribution_summary"]
    },
    "reader_question": {"type": "string"},
    "licensed_claims": {"type": "array", "items": {"type": "string"}},
    "required_evidence": {"type": "array", "items": {"type": "string"}},
    "new_information": {"type": "array", "items": {"type": "string"}},
    "must_not_include": {"type": "array", "items": {"type": "string"}},
    "transition_from": {"type": "string"},
    "transition_to": {"type": "string"},
    "target_length_words": {
      "type": "array",
      "prefixItems": [{"type": "integer", "minimum": 1}, {"type": "integer", "minimum": 1}],
      "minItems": 2,
      "maxItems": 2
    },
    "status": {"type": "string", "enum": ["draft", "author_confirmed", "used", "deprecated"]}
  },
  "additionalProperties": true
}
