{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scholar Papercraft Review Issue",
  "type": "object",
  "required": ["issue_id", "severity", "location", "type", "problem", "required_action", "rewrite_permission"],
  "properties": {
    "issue_id": {"type": "string"},
    "severity": {"type": "string", "enum": ["critical", "major", "minor", "note"]},
    "location": {"type": "string"},
    "type": {"type": "string"},
    "claim_id": {"type": "string"},
    "problem": {"type": "string"},
    "evidence_available": {"type": "array", "items": {"type": "string"}},
    "required_action": {"type": "string", "enum": ["downgrade", "support", "delete", "clarify_scope", "add_citation", "ask_author", "move", "no_action"]},
    "suggested_scope": {"type": "string"},
    "rewrite_permission": {"type": "string", "enum": ["none", "sentence_only", "paragraph_only", "section_plan", "author_input_required"]},
    "status": {"type": "string", "enum": ["open", "resolved", "blocked", "accepted_risk"]}
  },
  "additionalProperties": true
}
